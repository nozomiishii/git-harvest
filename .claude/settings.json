{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/startup.sh\""
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun install"
          }
        ]
      }
    ]
  }
}
