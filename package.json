{
  "name": "git-harvest",
  "version": "0.3.0",
  "description": "Clean up branches and worktrees",
  "keywords": [
    "git",
    "cli",
    "cleanup",
    "branch",
    "worktree"
  ],
  "homepage": "https://github.com/nozomiishii/git-harvest",
  "repository": {
    "type": "git",
    "url": "https://github.com/nozomiishii/git-harvest.git"
  },
  "license": "MIT",
  "author": "Nozomi Ishii",
  "type": "module",
  "bin": {
    "git-harvest": "./dist/cli.mjs"
  },
  "files": [
    "dist",
    "README.md",
    "README.ja.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsx lib/cli.ts --dry-run",
    "eslint": "eslint --max-warnings=0 --cache",
    "format": "pnpm prettier . --check",
    "format:fix": "pnpm prettier . --write",
    "lint": "pnpm eslint",
    "lint:fix": "pnpm eslint --fix",
    "prepare": "lefthook install --force",
    "prepublishOnly": "pnpm build",
    "prettier": "prettier --ignore-unknown --cache",
    "test": "vitest"
  },
  "devDependencies": {
    "@nozomiishii/commitlint-config": "1.7.0",
    "@nozomiishii/eslint-config": "1.7.0",
    "@nozomiishii/lefthook-config": "1.7.0",
    "@nozomiishii/prettier-config": "1.7.0",
    "@nozomiishii/tsconfig": "1.7.0",
    "@types/node": "24.13.2",
    "eslint": "10.4.1",
    "lefthook": "2.1.9",
    "prettier": "3.8.4",
    "release-please": "17.9.0",
    "tsdown": "0.22.2",
    "tsx": "4.22.4",
    "typescript": "6.0.3",
    "vitest": "4.1.8"
  },
  "packageManager": "pnpm@11.6.0",
  "engines": {
    "node": ">=24"
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": "24.16.0",
      "onFail": "error"
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
