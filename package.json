{
  "name": "git-harvest",
  "version": "0.2.3",
  "description": "Clean up branches and worktrees",
  "keywords": [
    "git",
    "cli",
    "cleanup",
    "branch",
    "worktree"
  ],
  "homepage": "https://github.com/nozomiishii/git-harvest",
  "repository": {
    "type": "git",
    "url": "https://github.com/nozomiishii/git-harvest.git"
  },
  "license": "MIT",
  "author": "Nozomi Ishii",
  "type": "module",
  "bin": {
    "git-harvest": "./lib/git-harvest"
  },
  "files": [
    "lib/git-harvest"
  ],
  "scripts": {
    "build": "echo 'no build step yet: lib/git-harvest is a shell script. tsdown is staged for the TypeScript migration (#180).'",
    "dev": "./lib/git-harvest --dry-run",
    "eslint": "eslint --max-warnings=0 --cache",
    "format": "pnpm prettier . --check",
    "format:fix": "pnpm prettier . --write",
    "install:local": "bash install.sh",
    "lint": "pnpm eslint",
    "lint:fix": "pnpm eslint --fix",
    "prepare": "lefthook install --force",
    "prettier": "prettier --ignore-unknown --cache",
    "test": "vitest",
    "uninstall:local": "bash uninstall.sh"
  },
  "devDependencies": {
    "@nozomiishii/commitlint-config": "1.7.0",
    "@nozomiishii/eslint-config": "1.7.0",
    "@nozomiishii/lefthook-config": "1.7.0",
    "@nozomiishii/prettier-config": "1.7.0",
    "@nozomiishii/tsconfig": "1.7.0",
    "@types/node": "24.13.1",
    "eslint": "10.4.1",
    "lefthook": "2.1.9",
    "prettier": "3.8.4",
    "release-please": "17.9.0",
    "tsdown": "0.22.2",
    "typescript": "6.0.3",
    "vitest": "4.1.8"
  },
  "packageManager": "pnpm@11.5.2",
  "engines": {
    "node": ">=24"
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": "24.16.0",
      "onFail": "error"
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
