{
  "name": "git-harvest",
  "version": "0.2.2",
  "author": "Nozomi Ishii",
  "repository": {
    "type": "git",
    "url": "https://github.com/nozomiishii/git-harvest.git"
  },
  "devDependencies": {
    "@nozomiishii/commitlint-config": "1.3.0",
    "@nozomiishii/eslint-config": "1.5.0",
    "@nozomiishii/lefthook-config": "1.3.0",
    "@nozomiishii/tsconfig": "1.5.0",
    "@types/bun": "1.3.14",
    "lefthook": "2.1.8",
    "release-please": "17.6.1",
    "tsdown": "0.22.1",
    "tsx": "4.22.4",
    "typescript": "6.0.3",
    "vitest": "4.1.7"
  },
  "bin": {
    "git-harvest": "dist/git-harvest"
  },
  "description": "Clean up branches and worktrees",
  "files": [
    "dist/git-harvest",
    "README*.md",
    "LICENSE"
  ],
  "homepage": "https://github.com/nozomiishii/git-harvest",
  "keywords": [
    "git",
    "cli",
    "cleanup",
    "branch",
    "worktree"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsx lib/cli.ts --dry-run",
    "prepack": "tsdown",
    "prepare": "lefthook install --force",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "install:local": "bash install.sh",
    "uninstall:local": "bash uninstall.sh"
  },
  "type": "module"
}
