  },
  "license": "MIT",
  "author": "Nozomi Ishii",
  "bin": {
    "git-harvest": "./lib/git-harvest"
  },
  "files": [
    "lib/git-harvest"
  ],
  "scripts": {
    "dev": "./lib/git-harvest --dry-run",
    "test": "bun test",
    "install:local": "bash install.sh",
    "uninstall:local": "bash uninstall.sh"
  },
  "devDependencies": {
    "@types/bun": "1.3.11",
