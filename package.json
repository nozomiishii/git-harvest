{
  "name": "git-harvest",
  "version": "0.2.2",
  "type": "module",
  "description": "Clean up branches and worktrees",
  "keywords": [
    "git",
    "cli",
    "cleanup",
    "branch",
    "worktree"
  ],
  "homepage": "https://github.com/nozomiishii/git-harvest",
  "repository": {
    "type": "git",
    "url": "https://github.com/nozomiishii/git-harvest.git"
  },
  "license": "MIT",
  "author": "Nozomi Ishii",
  "bin": {
    "git-harvest": "dist/git-harvest"
  },
  "files": [
    "dist/git-harvest",
    "README*.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "bun build lib/cli.ts --target=node --format=esm --banner '#!/usr/bin/env node' --outfile dist/git-harvest",
    "build:binary": "bun build lib/cli.ts --compile --target=bun-darwin-arm64 --outfile git-harvest-darwin-arm64",
    "dev": "bun lib/cli.ts --dry-run",
    "prepack": "bun run build",
    "prepare": "lefthook install --force",
    "test": "vitest run",
    "test:watch": "vitest",
    "install:local": "bash install.sh",
    "uninstall:local": "bash uninstall.sh"
  },
  "devDependencies": {
    "@nozomiishii/commitlint-config": "1.3.0",
    "@nozomiishii/eslint-config": "1.5.0",
    "@nozomiishii/lefthook-config": "1.3.0",
    "@types/bun": "1.3.14",
    "lefthook": "2.1.8",
    "release-please": "17.6.1",
    "typescript": "6.0.3",
    "vitest": "4.1.7"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "dependencies": {
    "execa": "9.6.1"
  }
}
